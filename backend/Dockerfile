# 1. Используем легковесный базовый образ Golang
FROM golang:1.26-alpine

# 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Копируем исходный код в контейнер
COPY . .

# 4. Компилируем Go-приложение и очищаем кэш
RUN go build -o myapp cmd/api/*.go && rm -rf /var/cache/*

# 5. Открываем порт 8081
EXPOSE 8081

# 6. Запускаем приложение
CMD ["./myapp"] 